@namespace Inspector.UI
@using Inspector.Hierarchy
@inherits Panel

<root class="inspector-view inspector-hierarchy-view">
	<div class="inspector-hierarchy-header">
		<div class="inspector-breadcrumb">s&box <i>chevron_right</i> Scene</div>
		<button><i>search</i></button>
		<button><i>filter_alt</i></button>
		<button><i>add</i></button>
	</div>

	<div class="inspector-filter-tabs">
		@foreach ( var filter in Filters )
		{
			<button class="inspector-filter-tab @(filter == ActiveFilter ? "is-active" : "")" @onclick="@(() => ActiveFilter = filter)">@filter</button>
		}
	</div>

	<div class="inspector-hierarchy-tree">
		<div class="inspector-hierarchy-row inspector-scene-row">
			<button class="inspector-tree-toggle" @onclick="@ToggleScene">
				<i>@(IsSceneExpanded ? "keyboard_arrow_down" : "keyboard_arrow_right")</i>
			</button>
			<i>deployed_code</i>
			<span class="inspector-hierarchy-name">Scene</span>
			<div class="spacer"></div>
			<i class="muted">visibility</i>
			<i class="muted">lock_open</i>
		</div>
		@foreach ( var node in Nodes )
		{
			<div class="inspector-hierarchy-row @(Service.SelectedGameObject == node.GameObject ? "is-selected" : "")" style="padding-left: @(10 + (node.Depth + 1) * 18)px" @onclick="@(() => Service.Select( node.GameObject ))">
				@if ( node.HasChildren )
				{
					<button class="inspector-tree-toggle" @onclick="@(() => ToggleNode( node ))">
						<i>@(IsCollapsed( node.GameObject ) ? "keyboard_arrow_right" : "keyboard_arrow_down")</i>
					</button>
				}
				else
				{
					<div class="inspector-tree-toggle"></div>
				}
				<i>@IconFor( node.GameObject )</i>
				<span class="inspector-hierarchy-name">@node.GameObject.Name</span>
				<div class="spacer"></div>
				<i class="muted">visibility</i>
				<i class="muted">lock_open</i>
			</div>
		}
	</div>

	<div class="inspector-view-footer">
		<div class="inspector-footer-actions">
			<button @onclick="@(() => Service.SetSearchText( string.Empty ))">Add Filter</button>
			<button @onclick="@ResetFilters">Reset</button>
		</div>
		<span>@Nodes.Count items</span>
	</div>
</root>
