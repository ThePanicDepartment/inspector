@namespace Inspector.UI
@inherits SingletonPanelComponent<InspectorPanel>

<root class="inspector-runtime @(Service?.IsOpen == true ? "is-open" : "is-closed")">
	@if ( CurrentService is not null )
	{
		<InspectorGizmoToolbar Service="@CurrentService" />
		<InspectorShell Service="@CurrentService" />
	}
</root>
